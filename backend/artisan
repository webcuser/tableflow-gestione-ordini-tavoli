#!/usr/bin/env php
<?php

declare(strict_types=1);

$argv = $_SERVER['argv'] ?? [];
$command = $argv[1] ?? null;

if ($command !== 'serve') {
    fwrite(STDERR, "Unsupported command. Available: serve\n");
    exit(1);
}

$host = '127.0.0.1';
$port = '8000';

for ($i = 2; $i < count($argv); $i++) {
    $arg = $argv[$i];

    if ($arg === '--host' && isset($argv[$i + 1])) {
        $host = $argv[++$i];
        continue;
    }

    if (str_starts_with($arg, '--host=')) {
        $host = substr($arg, 7);
        continue;
    }

    if ($arg === '--port' && isset($argv[$i + 1])) {
        $port = $argv[++$i];
        continue;
    }

    if (str_starts_with($arg, '--port=')) {
        $port = substr($arg, 7);
        continue;
    }
}

$publicPath = __DIR__ . '/public';
if (!is_dir($publicPath)) {
    fwrite(STDERR, "Missing public directory at {$publicPath}\n");
    exit(1);
}

$cmd = sprintf(
    'php -S %s:%s -t %s %s',
    escapeshellarg($host),
    escapeshellarg($port),
    escapeshellarg($publicPath),
    escapeshellarg($publicPath . '/index.php')
);

passthru($cmd, $exitCode);
exit($exitCode);
