{
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12.0",
    "nunomaduro/collision": "^7.0",
    "laravel/sanctum": "^3.0",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
